{
  "id": "/",
  "name": "Ambitionz",
  "short_name": "Ambitionz",
  "description": "Dark tactical fantasy card duels built around risk, intent, Sigils and Ambition.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "any",
  "background_color": "#05050B",
  "theme_color": "#05050B",
  "categories": [
    "games",
    "entertainment",
    "strategy"
  ],
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/static/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/static/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/static/icons/maskable-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/static/icons/maskable-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/static/icons/icon.svg",
      "sizes": "1024x1024",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Play Training",
      "short_name": "Play",
      "description": "Start a quick Ambitionz training match.",
      "url": "/training",
      "icons": [
        {
          "src": "/static/icons/icon.svg",
          "sizes": "1024x1024"
        }
      ]
    },
    {
      "name": "Feedback",
      "short_name": "Feedback",
      "description": "Send beta feedback.",
      "url": "/feedback",
      "icons": [
        {
          "src": "/static/icons/icon.svg",
          "sizes": "1024x1024"
        }
      ]
    }
  ]
}
