          "content": {
            "size": 20305,
            "mimeType": "text/html; charset=utf-8",
            "compression": 20989,
            "text": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>Jogar Ambitionz Rebirth</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, viewport-fit=cover\">\n    <meta name=\"theme-color\" content=\"#030405\">\n    <meta name=\"description\" content=\"Jogue Ambitionz Rebirth: invoque monstros, escolha alvos e quebre a guarda em uma arena TCG persistente.\">\n    <link rel=\"manifest\" href=\"/static/manifest.webmanifest\">\n    <link rel=\"icon\" href=\"/static/icons/icon.svg\">\n    <link rel=\"preload\" as=\"image\" href=\"/static/assets/rebirth/cards/dreadclaw-art.webp\" type=\"image/webp\">\n    <link rel=\"stylesheet\" href=\"/static/css/rebirth.css?v=v74_COMBAT_REWORK-4\">\n</head>\n<body class=\"rb-page rb-game-page\">\n    \n\n<header class=\"rb-global-nav\" data-rebirth-global-nav data-rebirth-wallet aria-label=\"Navegação global Ambitionz Rebirth\">\n    <a class=\"rb-brand rb-global-brand\" href=\"/\" aria-label=\"Ambitionz Rebirth início\">\n        <span>A</span>\n        <strong>Ambitionz Rebirth</strong>\n    </a>\n    <nav class=\"rb-global-tabs\" aria-label=\"Produtos Rebirth\">\n        <a href=\"/rebirth\" class=\"is-active\">Arena</a>\n        <a href=\"/rebirth/campaign\" class=\"\">Campanha</a>\n        <a href=\"/rebirth/collection\" class=\"\">Coleção</a>\n        <a href=\"/rebirth/shop\" class=\"\">Loja</a>\n        <a href=\"/rebirth/progression\" class=\"\">Recompensas</a>\n        <a href=\"/rebirth/profile\" class=\"\">Perfil</a>\n    </nav>\n    <section class=\"rb-global-player\" aria-label=\"Jogador e carteira\">\n        <div class=\"rb-global-identity\">\n            <span>Visitante</span>\n            <strong data-rebirth-username>Visitante</strong>\n        </div>\n        <div class=\"rb-global-xp\" aria-label=\"Nível e XP\">\n            <span>Nível 1</span>\n            <strong>0/500 XP</strong>\n            <i aria-hidden=\"true\"><b style=\"width: 0%\"></b></i>\n        </div>\n        <div class=\"rb-global-wallet\" aria-label=\"Carteira\">\n            <span>Ouro <strong data-rebirth-wallet-value=\"GOLD\">0</strong></span>\n            <span class=\"rb-coinz\">Gemas <strong data-rebirth-wallet-value=\"COINZ\">0</strong></span>\n        </div>\n        \n            <button class=\"rb-nav-auth\" type=\"button\" data-rebirth-auth-open>Entrar / Cadastrar</button>\n        \n    </section>\n</header>\n\n<div class=\"rb-auth-modal\" data-rebirth-auth-modal hidden>\n    <button class=\"rb-auth-backdrop\" type=\"button\" data-rebirth-auth-close aria-label=\"Fechar login\"></button>\n    <section class=\"rb-auth-dialog\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"rebirth-auth-title\">\n        <button class=\"rb-auth-close\" type=\"button\" data-rebirth-auth-close aria-label=\"Fechar\">x</button>\n        <div class=\"rb-auth-dialog-copy\">\n            <span>Ambitionz Rebirth</span>\n            <h2 id=\"rebirth-auth-title\">Entrar / Cadastrar</h2>\n            <p>Entre para guardar sua coleção, nível, Ouro e Gemas entre duelos.</p>\n        </div>\n        <div class=\"rb-auth-modal-grid\">\n            <form class=\"rb-auth-form rb-auth-modal-form\" data-rebirth-login data-auth-redirect=\"/rebirth\">\n                <span>Entrar</span>\n                <label>Email<input name=\"email\" type=\"text\" inputmode=\"email\" autocomplete=\"email\" required></label>\n                <label>Senha<input name=\"password\" type=\"password\" autocomplete=\"current-password\" required></label>\n                <button class=\"rb-button-secondary rb-secondary\" type=\"submit\">Entrar</button>\n            </form>\n            <form class=\"rb-auth-form rb-auth-modal-form\" data-rebirth-register data-auth-redirect=\"/rebirth?firstRun=1\">\n                <span>Cadastrar</span>\n                <label>Jogador<input name=\"username\" autocomplete=\"username\" required minlength=\"3\"></label>\n                <label>Email<input name=\"email\" type=\"text\" inputmode=\"email\" autocomplete=\"email\" required></label>\n                <label>Senha<input name=\"password\" type=\"password\" autocomplete=\"new-password\" required minlength=\"8\"></label>\n                <button class=\"rb-button-primary rb-cta\" type=\"submit\">Criar conta</button>\n            </form>\n        </div>\n        <div class=\"rb-product-result rb-auth-modal-result\" data-rebirth-auth-result aria-live=\"polite\">Pronto.</div>\n    </section>\n</div>\n    <div class=\"rb-game-viewport\" data-rebirth-app data-board-base-width=\"852\" data-board-base-height=\"1846\" aria-label=\"Ambitionz Rebirth jogo de tela única\">\n        <aside class=\"rb-desktop-rail rb-desktop-rail-left\" aria-label=\"Status Rebirth\">\n            <a class=\"rb-brand rb-rail-brand\" href=\"/\" aria-label=\"Início Ambitionz\">\n                <span>A</span>\n                <strong>Ambitionz Rebirth</strong>\n            </a>\n            <article>\n                <span>Modo</span>\n                <strong>Mesa TCG ao vivo</strong>\n            </article>\n            <article>\n                <span>Baralho</span>\n                <strong>30 cartas</strong>\n            </article>\n            <nav aria-label=\"Links do produto Rebirth\">\n                <a href=\"/rebirth/collection\">Coleção</a>\n                <a href=\"/rebirth/shop\">Loja</a>\n                <a href=\"/rebirth/progression\">Recompensas</a>\n                <a href=\"/rebirth/profile\">Perfil</a>\n            </nav>\n        </aside>\n\n        <main id=\"rebirth-board\" class=\"rb-game-board rb-clash-shell\" aria-label=\"Interface do clash Ambitionz Rebirth\">\n            <section class=\"rb-hud\" aria-label=\"HUD da partida\">\n                <div class=\"rb-hud-side rb-hud-player\">\n                    <a class=\"rb-mark\" href=\"/\" aria-label=\"Início Ambitionz\">A</a>\n                    <div class=\"rb-hud-copy\">\n                        <span>Você</span>\n                        <div class=\"rb-hud-health\" data-health-side=\"player\">\n                            <div class=\"rb-hp-meter rb-life-orb\" data-health-state=\"stable\" aria-hidden=\"true\">\n                                <b id=\"player-hp-fill\"></b>\n                                <span class=\"rb-life-orb__glass\"></span>\n                                <span class=\"rb-life-orb__runes\"></span>\n                            </div>\n                            <div class=\"rb-life-orb-readout\">\n                                <i aria-hidden=\"true\"></i>\n                                <strong id=\"player-hp\">30</strong>\n                                <small>HP</small>\n                            </div>\n                        </div>\n                        <div class=\"rb-zone-row\" aria-label=\"Zonas do jogador\">\n                            <span>Mana <b id=\"player-energy\">1</b>/<b id=\"player-max-energy\">1</b></span>\n                            <span id=\"player-deck-count\">Baralho 0</span>\n                            <span id=\"player-discard-count\">Descarte 0</span>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"rb-turn-core rb-hud-turn\">\n                    <span>Turno</span>\n                    <strong id=\"turn-number\">01</strong>\n                    <small id=\"phase-hud-label\">Principal</small>\n                    <div id=\"phase-timeline\" class=\"rb-phase-timeline\" aria-label=\"Linha do turno\">\n                        <i data-phase-step=\"draw\" title=\"Compra\"></i>\n                        <i data-phase-step=\"main\" title=\"Principal\"></i>\n                        <i data-phase-step=\"combat\" title=\"Combate\"></i>\n                        <i data-phase-step=\"end\" title=\"Fim\"></i>\n                    </div>\n                    <small id=\"bot-profile-label\" class=\"rb-visually-hidden\">Perfil do bot</small>\n                </div>\n\n                <div class=\"rb-hud-side rb-hud-bot\">\n                    <div class=\"rb-hud-copy\">\n                        <span>Bot</span>\n                        <div class=\"rb-hud-health\" data-health-side=\"bot\">\n                            <div class=\"rb-hp-meter rb-life-orb\" data-health-state=\"stable\" aria-hidden=\"true\">\n                                <b id=\"bot-hp-fill\"></b>\n                                <span class=\"rb-life-orb__glass\"></span>\n                                <span class=\"rb-life-orb__runes\"></span>\n                            </div>\n                            <div class=\"rb-life-orb-readout\">\n                                <i aria-hidden=\"true\"></i>\n                                <strong id=\"bot-hp\">30</strong>\n                                <small>HP</small>\n                            </div>\n                        </div>\n                        <div class=\"rb-zone-row\" aria-label=\"Zonas do bot\">\n                            <span>Mana <b id=\"bot-energy\">1</b>/<b id=\"bot-max-energy\">1</b></span>\n                            <span id=\"bot-deck-count\">Baralho 0</span>\n                            <span id=\"bot-discard-count\">Descarte 0</span>\n                        </div>\n                    </div>\n                    <div class=\"rb-bot-emblem\" aria-hidden=\"true\"></div>\n                </div>\n            </section>\n\n            <section class=\"rb-battle-zone battlefield-living\" data-battlefield-living aria-label=\"Zona de batalha\">\n                <!-- v55 Fase 3: parallax de 3 camadas. JS aplica translate3d\n                     em cada camada baseado na posição do mouse pra ilusão\n                     de profundidade volumétrica. Foreground reage mais forte\n                     (4px), board moderado (-3px), skybox sutil (-8px na\n                     direção contrária pra sensação de distância). -->\n                <div class=\"battlefield-layer battlefield-layer-skybox\" data-parallax-depth=\"-8\" aria-hidden=\"true\">\n                    <div class=\"battlefield-embers\" aria-hidden=\"true\">\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 12%; --ember-delay: 0s; --ember-size: 4px\"></i>\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 28%; --ember-delay: -3s; --ember-size: 3px\"></i>\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 44%; --ember-delay: -7s; --ember-size: 5px\"></i>\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 62%; --ember-delay: -1s; --ember-size: 3px\"></i>\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 78%; --ember-delay: -5s; --ember-size: 4px\"></i>\n                        <i class=\"battlefield-ember\" style=\"--ember-x: 90%; --ember-delay: -2s; --ember-size: 3px\"></i>\n                    </div>\n                </div>\n                <div class=\"battlefield-layer battlefield-layer-board\" data-parallax-depth=\"-3\" aria-hidden=\"true\"></div>\n                <div class=\"battlefield-layer battlefield-layer-foreground\" data-parallax-depth=\"4\" aria-hidden=\"true\"></div>\n                <div class=\"rb-field-row rb-field-row-bot\">\n                    <span>Zona do Bot</span>\n                    <div id=\"bot-battlefield\" class=\"rb-field-slots\" aria-label=\"Monstros invocados pelo bot\"></div>\n                </div>\n                <div class=\"rb-bot-card-zone\" aria-label=\"Carta do bot\">\n                    <div id=\"bot-card\" class=\"rb-bot-card rb-card-back\">\n                        <span>Carta do bot</span>\n                    </div>\n                </div>\n                <div class=\"rb-field-vs\" aria-hidden=\"true\">VS</div>\n                <div class=\"rb-field-row rb-field-row-player\">\n                    <span>Sua Zona</span>\n                    <div id=\"player-battlefield\" class=\"rb-field-slots\" aria-label=\"Seus monstros invocados\"></div>\n                </div>\n            </section>\n\n            <section class=\"rb-card-stage\" aria-label=\"Monstro selecionado e evolução\">\n                <article id=\"focus-card\" class=\"rb-main-card rb-monster-card rb-monster-card-main rb-empty-card\" aria-live=\"polite\">\n                    <div class=\"rb-card-topline\">\n                        <div>\n                            <strong>Selecione um monstro</strong>\n                            <span>Pronto</span>\n                        </div>\n                        <b class=\"rb-card-rank\">?</b>\n                    </div>\n                    <div class=\"rb-card-art rb-asset-fallback\">\n                        <span>Escolher</span>\n                    </div>\n                    <div class=\"rb-card-rule\">\n                        <strong>Campo de batalha vivo</strong>\n                        <p>Monstros invocados permanecem em campo até sua Guarda zerar.</p>\n                    </div>\n                    <div class=\"rb-card-stats\">\n                        <span><i class=\"rb-stat-sword\"></i><b>0</b></span>\n                        <span><i class=\"rb-stat-crest\"></i></span>\n                        <span><i class=\"rb-stat-shield\"></i><b>0</b></span>\n                    </div>\n                </article>\n\n                <aside id=\"evolution-panel\" class=\"rb-duplicate-panel rb-evolution-panel\" aria-live=\"polite\">\n                    <span id=\"evolution-status\">Duplicata encontrada</span>\n                    <div id=\"evolution-card-thumbnail\" class=\"rb-evolution-thumb rb-asset-fallback\" aria-hidden=\"true\"></div>\n                    <strong id=\"evolution-name\">Monstro x2</strong>\n                    <small>Combine duplicatas para evoluir.</small>\n                    <button class=\"rb-button-secondary rb-secondary rb-combine-button\" type=\"button\" id=\"evolve-button\">Evoluir</button>\n                </aside>\n            </section>\n\n            <section id=\"rebirth-action-bar\" class=\"rb-mobile-action-bar\" aria-label=\"Mão e ações principais\">\n                <section class=\"rb-player-hand rb-hand-wrap\" aria-label=\"Mão do jogador\">\n                    <div class=\"rb-action-bar-meta\" aria-live=\"polite\">\n                        <span id=\"action-selected-card\">Escolha uma carta</span>\n                        <strong id=\"action-mana-label\">Mana 0/0</strong>\n                    </div>\n                    <div id=\"player-hand\" class=\"rb-hand\"></div>\n                    <span id=\"hand-count\" class=\"rb-hand-count\">0 cartas</span>\n                </section>\n\n                <section class=\"rb-actions rb-actions-row\" aria-label=\"Ações principais\">\n                    <div>\n                        <button class=\"rb-button-primary rb-cta\" type=\"button\" id=\"play-button\"><i class=\"rb-action-sword\"></i>Invocar</button>\n                        <small id=\"primary-action-copy\">Gaste mana para jogar</small>\n                    </div>\n                    <div>\n                        <button class=\"rb-button-secondary rb-secondary rb-action-combine\" type=\"button\" id=\"next-turn-button\"><i class=\"rb-action-loop\"></i>Encerrar turno</button>\n                        <small id=\"secondary-action-copy\">Passe a vez para recarregar mana</small>\n                    </div>\n                </section>\n            </section>\n\n            <section class=\"rb-result rb-result-panel\" id=\"result-panel\" aria-live=\"polite\">\n                <div>\n                    <span id=\"result-label\">Aguardando</span>\n                    <strong id=\"result-title\">Monte seu campo.</strong>\n                    <p id=\"result-copy\">Invoque monstros, depois escolha um atacante e um alvo.</p>\n                    <div class=\"rb-resolution-strip\" id=\"resolution-strip\" aria-label=\"Resolucao atual\">\n                        <span id=\"priority-label\">Prioridade: jogador</span>\n                        <span id=\"chain-label\">Sem cadeia ativa</span>\n                        <span id=\"interrupt-label\">Janela fechada</span>\n                    </div>\n                    <div id=\"tactics-strip\" class=\"rb-tactics-strip\" aria-label=\"Leitura tática\"></div>\n                    <div id=\"reward-panel\" class=\"rb-reward-panel\" aria-live=\"polite\"></div>\n                    <div id=\"ability-events\" class=\"rb-ability-events\" aria-live=\"polite\"></div>\n                    <div id=\"progression-tease\" class=\"rb-progression-tease\" aria-live=\"polite\" hidden></div>\n                    <div id=\"campaign-defeat-advice\" class=\"rb-campaign-defeat-advice\" aria-live=\"polite\" hidden></div>\n                </div>\n                <div class=\"rb-result-actions\" id=\"result-actions\">\n                    <button class=\"rb-button-primary rb-cta rb-rematch-cta\" type=\"button\" id=\"rematch-button\" data-new-match hidden>\n                        <i class=\"rb-action-loop\" aria-hidden=\"true\"></i>Jogar de novo\n                    </button>\n                    <button class=\"rb-button-secondary rb-secondary\" type=\"button\" data-new-match>Nova partida</button>\n                </div>\n            </section>\n\n            <section class=\"rb-turn-log rb-log\" aria-label=\"Histórico do turno\">\n                <div class=\"rb-log-head\">\n                    <strong>Histórico</strong>\n                    <span id=\"phase-label\">escolher</span>\n                </div>\n                <ol id=\"turn-log\"></ol>\n            </section>\n\n            <div class=\"rb-loading\" id=\"rebirth-loading\" aria-hidden=\"true\">Carregando</div>\n            <div class=\"rb-error\" id=\"rebirth-error\" aria-live=\"polite\"></div>\n\n            <!-- v55 Fase 4: containers das animações de assinatura. Ficam\n                 ocultos por padrão; o JS injeta conteúdo + classes ativas. -->\n            <div class=\"vfx-evolution-stage\" id=\"rebirth-evolution-stage\" aria-hidden=\"true\"></div>\n            <div class=\"vfx-finale-overlay\" id=\"rebirth-finale-overlay\" role=\"status\" aria-live=\"polite\" aria-hidden=\"true\"></div>\n            <div class=\"rb-boss-intro-overlay\" id=\"rebirth-boss-intro\" role=\"status\" aria-live=\"polite\" aria-hidden=\"true\"></div>\n        </main>\n\n        <aside class=\"rb-desktop-rail rb-desktop-rail-right\" aria-label=\"Guia da partida\">\n            <article>\n                <span id=\"guide-rule-label\">Regra</span>\n                <strong id=\"guide-rule-title\">Invoque e ataque</strong>\n                <p id=\"guide-rule-copy\">Monstros ficam no campo até a Guarda chegar a zero.</p>\n            </article>\n            <article>\n                <span id=\"guide-combine-label\">Combinar</span>\n                <strong id=\"guide-combine-title\">Duplicatas evoluem</strong>\n                <p id=\"guide-combine-copy\">Dois monstros iguais se fundem em sua forma Rebirth.</p>\n            </article>\n            <a class=\"rb-secondary\" href=\"/rebirth/desktop\">Notas de desktop</a>\n        </aside>\n    </div>\n\n    <script>\n        window.REBIRTH_CSRF = \"OUVc9RYUk7g4pR7vMH7L0h6cWwMiXhgGchL57geoEo8\";\n        window.REBIRTH_ENDPOINTS = {\n            start: \"/api/rebirth/start\",\n            campaignStart: \"/api/rebirth/campaign/start\",\n            playCard: \"/api/rebirth/play-card\",\n            attack: \"/api/rebirth/attack\",\n            evolve: \"/api/rebirth/evolve\",\n            labsFusion: \"/api/labs/fusion\",\n            nextTurn: \"/api/rebirth/next-turn\",\n            completeTutorial: \"/api/rebirth/onboarding/complete\",\n            verifyReceipt: \"/api/rebirth/shop/verify-receipt\",\n            wallet: \"/api/rebirth/wallet\",\n            register: \"/api/rebirth/auth/register\",\n            login: \"/api/rebirth/auth/login\",\n            logout: \"/api/rebirth/auth/logout\",\n            telemetry: \"/api/rebirth/telemetry\"\n        };\n        window.REBIRTH_AUTH_ENDPOINTS = {\n            register: \"/api/rebirth/auth/register\",\n            login: \"/api/rebirth/auth/login\",\n            logout: \"/api/rebirth/auth/logout\",\n            wallet: \"/api/rebirth/wallet\"\n        };\n        window.REBIRTH_PLAYER_CONTEXT = {\"account\": {\"authenticated\": false, \"user\": null}, \"progression\": {}};\n        window.REBIRTH_ASSETS = {\n            fallbackCardArt: \"/static/assets/rebirth/cards/dreadclaw-art.webp\",\n            botCardBack: \"/static/assets/rebirth/ui/bot-card-back.png\",\n            botEmblem: \"/static/assets/rebirth/ui/bot-emblem.png\",\n            manifest: \"/static/assets/rebirth/manifest.json\"\n        };\n    </script>\n    <script src=\"/static/js/pwa.js?v=v74_COMBAT_REWORK-4\"></script>\n    <script src=\"/static/js/rebirth_global.js?v=v74_COMBAT_REWORK-4\"></script>\n    <script src=\"/static/js/rebirth_audio.js?v=v74_COMBAT_REWORK-4\"></script>\n    <script src=\"/static/js/rebirth_ui.js?v=v74_COMBAT_REWORK-4\"></script>\n    <script src=\"/static/js/rebirth_fx.js?v=v74_COMBAT_REWORK-4\"></script>\n    <script src=\"/static/js/rebirth_boss_fx.js?v=v75_CAMPAIGN_ERA-1\"></script>\n    <script src=\"/static/js/rebirth.js?v=v74_COMBAT_REWORK-4\"></script>\n</body>\n</html>"
