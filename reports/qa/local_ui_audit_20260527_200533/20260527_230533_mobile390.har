            "mimeType": "application/manifest+json",
            "compression": 0,
            "text": "{\n  \"id\": \"/\",\n  \"name\": \"Ambitionz Rebirth\",\n  \"short_name\": \"Ambitionz\",\n  \"description\": \"A fast one-card monster duel. Combine duplicates, evolve monsters and win the clash.\",\n  \"start_url\": \"/rebirth?source=pwa\",\n  \"scope\": \"/\",\n  \"display\": \"standalone\",\n  \"display_override\": [\n    \"standalone\",\n    \"minimal-ui\",\n    \"browser\"\n  ],\n  \"orientation\": \"portrait-primary\",\n  \"background_color\": \"#050608\",\n  \"theme_color\": \"#050608\",\n  \"categories\": [\n    \"games\",\n    \"strategy\"\n  ],\n  \"lang\": \"en\",\n  \"dir\": \"ltr\",\n  \"prefer_related_applications\": false,\n  \"icons\": [\n    {\n      \"src\": \"/static/icons/icon-192.png\",\n      \"sizes\": \"192x192\",\n      \"type\": \"image/png\",\n      \"purpose\": \"any\"\n    },\n    {\n      \"src\": \"/static/icons/icon-512.png\",\n      \"sizes\": \"512x512\",\n      \"type\": \"image/png\",\n      \"purpose\": \"any\"\n    },\n    {\n      \"src\": \"/static/icons/maskable-icon-192.png\",\n      \"sizes\": \"192x192\",\n      \"type\": \"image/png\",\n      \"purpose\": \"maskable\"\n    },\n    {\n      \"src\": \"/static/icons/maskable-icon-512.png\",\n      \"sizes\": \"512x512\",\n      \"type\": \"image/png\",\n      \"purpose\": \"maskable\"\n    },\n    {\n      \"src\": \"/static/icons/icon.svg\",\n      \"sizes\": \"1024x1024\",\n      \"type\": \"image/svg+xml\",\n      \"purpose\": \"any\"\n    }\n  ],\n  \"shortcuts\": [\n    {\n      \"name\": \"Play Rebirth\",\n      \"short_name\": \"Play\",\n      \"description\": \"Start a one-card Ambitionz Rebirth duel.\",\n      \"url\": \"/rebirth\",\n      \"icons\": [\n        {\n          \"src\": \"/static/icons/icon.svg\",\n          \"sizes\": \"1024x1024\"\n        }\n      ]\n    }\n  ]\n}\n"
