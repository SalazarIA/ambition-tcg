<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Arena - Ambition TCG</title>

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#070711">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Ambition">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="format-detection" content="telephone=no">

    <link rel="manifest" href="{{ url_for('static', filename='manifest.webmanifest') }}">
    <link rel="apple-touch-icon" href="{{ url_for('static', filename='icons/icon.svg') }}">
    <link rel="icon" href="{{ url_for('static', filename='icons/icon.svg') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
</head>
<body class="arena-body ios-safe-body">
    <div id="network-status-banner" class="network-banner online">Online</div>

    <main id="arena" class="mobile-arena ios-arena">
        <header class="arena-header mobile-arena-header compact-arena-header">
            <div>
                <h1>Ambition Arena</h1>
                <p>Round <span id="round">1</span> — <span id="phase-label">Set Phase</span></p>
            </div>

            <a href="{{ url_for('index') }}" class="btn btn-secondary small-btn">Leave</a>
        </header>

        {% if match_mode == "private" %}
            <section class="private-room-code-panel">
                <strong>Private Room</strong>
                <span id="private-room-code">{{ private_code }}</span>
                <button type="button" class="btn btn-secondary small-btn" onclick="copyPrivateRoomCode()">Copy</button>
            </section>
        {% endif %}

        <section class="arena-tip-panel compact-tip-panel">
            <strong>Turn Guide</strong>
            <span id="arena-step-text">Play 1 monster and optionally 1 spell/trap. Choose Intent. Then press Ready.</span>
        </section>

        <details class="arena-rules-panel compact-rules-panel">
            <summary>Quick Rules</summary>
            <div class="quick-rules-grid">
                <div><strong>Energy</strong><span>Cards cost energy. Energy grows each round.</span></div>
                <div><strong>Ambition</strong><span>Use aggressive plays to build Ambition.</span></div>
                <div><strong>Unleash</strong><span>Spend 5 Ambition for battle power.</span></div>
                <div><strong>Overreach</strong><span>Too much Ambition causes damage.</span></div>
                <div><strong>Elements</strong><span>Fire &gt; Plant &gt; Earth &gt; Water &gt; Fire.</span></div>
                <div><strong>Intents</strong><span>Strike, Guard or Focus before Ready.</span></div>
            </div>
        </details>

        <section class="mobile-hp-row compact-hp-row">
            <div class="compact-player-card enemy-compact">
                <span id="enemy-name">Searching...</span>
                <strong id="enemy-hp">4000</strong>
                <small>Enemy HP</small>
            </div>

            <div class="round-orb">
                <span>R</span>
                <strong id="round-mobile">1</strong>
            </div>

            <div class="compact-player-card my-compact">
                <span>{{ user.username }}</span>
                <strong id="my-hp">4000</strong>
                <small>Your HP</small>
            </div>
        </section>

        <section class="mobile-counts energy-counts">
            <div>Your Energy: <strong id="my-energy">0/0</strong></div>
            <div>Enemy Energy: <strong id="enemy-energy">0/0</strong></div>
        </section>

        <section class="ambition-row compact-ambition-row">
            <div class="ambition-box">
                <div class="ambition-label">
                    <span>Your Ambition</span>
                    <strong id="my-ambition-text">0/10</strong>
                </div>
                <div class="ambition-bar">
                    <div id="my-ambition-fill" class="ambition-fill"></div>
                </div>
            </div>

            <div class="ambition-box">
                <div class="ambition-label">
                    <span>Enemy Ambition</span>
                    <strong id="enemy-ambition-text">0/10</strong>
                </div>
                <div class="ambition-bar">
                    <div id="enemy-ambition-fill" class="ambition-fill enemy"></div>
                </div>
            </div>
        </section>

        <section class="board enemy-board mobile-board compact-board">
            <div class="zone mobile-zone cinematic-zone" id="enemy-st-zone">
                <span>Enemy Spell/Trap</span>
            </div>

            <div class="zone mobile-zone cinematic-zone" id="enemy-monster-zone">
                <span>Enemy Monster</span>
            </div>
        </section>

        <section class="arena-action-panel">
            <section class="intent-panel compact-intent-panel">
                <h3>Intent</h3>

                <div class="intent-buttons">
                    <button type="button" id="intent-strike" class="intent-btn active" onclick="chooseIntent('Strike')">
                        <strong>Strike</strong>
                        <span>Power risk</span>
                    </button>

                    <button type="button" id="intent-guard" class="intent-btn" onclick="chooseIntent('Guard')">
                        <strong>Guard</strong>
                        <span>Reduce damage</span>
                    </button>

                    <button type="button" id="intent-focus" class="intent-btn" onclick="chooseIntent('Focus')">
                        <strong>Focus</strong>
                        <span>Gain Ambition</span>
                    </button>
                </div>

                <button type="button" id="btn-unleash" class="btn btn-secondary full-btn ambition-unleash-btn" onclick="toggleUnleash()">
                    Unleash — Cost 5
                </button>
            </section>

            <section class="controls sticky-controls ios-sticky-controls">
                <button id="btn-ready" class="btn full-btn" onclick="declareReady()">Ready for Battle</button>
            </section>
        </section>

        <section class="board my-board mobile-board compact-board">
            <div class="zone mobile-zone cinematic-zone" id="my-monster-zone">
                <span>My Monster</span>
            </div>

            <div class="zone mobile-zone cinematic-zone" id="my-st-zone">
                <span>My Spell/Trap</span>
            </div>
        </section>

        <details class="battle-log-drawer" open>
            <summary>Battle Log</summary>
            <section id="battle-log" class="mobile-battle-log enhanced-battle-log compact-battle-log"></section>
        </details>

        <section class="mobile-counts">
            <div>My deck: <strong id="my-deck-count">0</strong></div>
            <div>My grave: <strong id="my-graveyard-count">0</strong></div>
            <div>Enemy hand: <strong id="enemy-hand-count">0</strong></div>
        </section>

        <section class="mobile-hand-section ios-hand-section">
            <h3 class="hand-title">Your Hand</h3>
            <p class="arena-helper">Playable cards glow. Swipe horizontally to view your hand.</p>
            <div id="my-hand" class="mobile-hand ios-mobile-hand"></div>
        </section>
    </main>

    <script>
        window.AMBITION_MATCH_MODE = "{{ match_mode|default('random') }}";
        window.AMBITION_PRIVATE_CODE = "{{ private_code|default('') }}";
    </script>

    <script src="{{ url_for('static', filename='js/pwa.js') }}"></script>
    <script src="{{ url_for('static', filename='js/game.js') }}"></script>
    <script type="module" src="{{ url_for('static', filename='js/mobile-native.js') }}"></script>
</body>
</html>
