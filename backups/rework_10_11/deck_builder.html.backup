<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Deck Builder - Ambition TCG</title>

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#8e44ad">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Ambition">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <link rel="manifest" href="{{ url_for('static', filename='manifest.webmanifest') }}">
    <link rel="icon" href="{{ url_for('static', filename='icons/icon.svg') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <main class="wide-page mobile-wide-page deck-builder-page">
        <header class="top-bar mobile-top-bar">
            <div>
                <h1>Deck Builder</h1>
                <p>30 to 40 cards. Beta target: 70% monsters, 20% spells, 10% traps.</p>
            </div>

            <a href="{{ url_for('index') }}" class="btn btn-secondary small-btn">Back</a>
        </header>

        {% with messages = get_flashed_messages() %}
            {% if messages %}
                <div class="flash-list">
                    {% for message in messages %}
                        <div class="flash">{{ message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        {% endwith %}

        <section class="deck-status mobile-deck-status">
            <h2>Current Deck</h2>

            {% if deck_validation_errors %}
                <div class="danger-box">
                    {% for error in deck_validation_errors %}
                        <p>{{ error }}</p>
                    {% endfor %}
                </div>
            {% else %}
                <div class="success-box">
                    <p>Deck is valid.</p>
                </div>
            {% endif %}

            <div class="deck-list compact-deck-list">
                {% for card in current_deck %}
                    <div class="deck-line">
                        <span>{{ card.name }}</span>
                        <strong>x{{ card.amount }}</strong>
                    </div>
                {% endfor %}
            </div>
        </section>

        <section class="mobile-filter-panel">
            <input id="builder-search" type="search" placeholder="Search card..." oninput="filterBuilderCards()">

            <select id="builder-type-filter" onchange="filterBuilderCards()">
                <option value="">All types</option>
                <option value="Monster">Monster</option>
                <option value="Spell">Spell</option>
                <option value="Trap">Trap</option>
            </select>

            <select id="builder-element-filter" onchange="filterBuilderCards()">
                <option value="">All elements</option>
                <option value="Fire">Fire</option>
                <option value="Water">Water</option>
                <option value="Earth">Earth</option>
                <option value="Plant">Plant</option>
                <option value="Global">Global</option>
            </select>
        </section>

        <form method="POST">
            <section class="builder-layout mobile-card-grid">
                {% for card in collection_cards %}
                    {% if card.owned > 0 %}
                        <article
                            class="builder-card image-card {{ card.type|lower }} {{ card.rarity|lower }}"
                            data-name="{{ card.name }}"
                            data-type="{{ card.type }}"
                            data-element="{{ card.element }}"
                        >
                            <div class="image-card-frame">
                                <header class="image-card-header">
                                    <h4>{{ card.name }}</h4>
                                    <span>{{ card.rarity }}</span>
                                </header>

                                <div class="image-card-art">
                                    <img
                                        src="{{ url_for('static', filename='img/' + card.image) }}"
                                        alt="{{ card.name }}"
                                        onerror="this.onerror=null; this.src='{{ url_for('static', filename='img/cards/placeholders/card_placeholder.svg') }}';"
                                    >
                                </div>

                                <div class="image-card-meta">
                                    <span>{{ card.element }}</span>
                                    <span>{{ card.type }}</span>
                                </div>

                                <div class="image-card-effect">
                                    <p>{{ card.description }}</p>
                                </div>

                                <footer class="image-card-footer">
                                    {% if card.type == "Monster" %}
                                        <span>POWER</span>
                                        <strong>{{ card.power }}</strong>
                                    {% else %}
                                        <span>VALUE</span>
                                        <strong>{{ card.value }}</strong>
                                    {% endif %}
                                </footer>
                            </div>

                            <div class="copy-select">
                                {% for n in range(card.owned) %}
                                    <label>
                                        <input
                                            type="checkbox"
                                            name="deck_cards"
                                            value="{{ card.id }}"
                                            onchange="updateDeckCounter()"
                                            {% if card.id in deck_ids and loop.index <= deck_ids.count(card.id) %}checked{% endif %}
                                        >
                                        Copy {{ loop.index }}
                                    </label>
                                {% endfor %}
                            </div>
                        </article>
                    {% endif %}
                {% endfor %}
            </section>

            <div class="save-deck-bar mobile-save-bar">
                <div class="deck-counter">
                    Selected: <strong id="selected-count">0</strong>
                </div>

                <button type="submit" class="btn full-btn">Save Deck</button>
            </div>
        </form>

        <nav class="mobile-bottom-nav">
            <a href="{{ url_for('index') }}">Home</a>
            <a href="{{ url_for('arena') }}">Arena</a>
            <a href="{{ url_for('deck_builder') }}" class="active">Deck</a>
            <a href="{{ url_for('shop') }}">Shop</a>
        </nav>
    </main>

    <script>
        function filterBuilderCards() {
            const search = document.getElementById("builder-search").value.toLowerCase();
            const type = document.getElementById("builder-type-filter").value;
            const element = document.getElementById("builder-element-filter").value;

            document.querySelectorAll(".builder-card").forEach((card) => {
                const cardName = card.dataset.name.toLowerCase();
                const cardType = card.dataset.type;
                const cardElement = card.dataset.element;

                const matchesSearch = cardName.includes(search);
                const matchesType = !type || cardType === type;
                const matchesElement = !element || cardElement === element;

                card.style.display = matchesSearch && matchesType && matchesElement ? "" : "none";
            });
        }

        function updateDeckCounter() {
            const count = document.querySelectorAll('input[name="deck_cards"]:checked').length;
            document.getElementById("selected-count").textContent = count;
        }

        document.addEventListener("DOMContentLoaded", updateDeckCounter);
    </script>

    <script src="{{ url_for('static', filename='js/pwa.js') }}"></script>
</body>
</html>