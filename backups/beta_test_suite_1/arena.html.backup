<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Arena - Ambition TCG</title>

    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta name="theme-color" content="#8e44ad">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Ambition">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <link rel="manifest" href="{{ url_for('static', filename='manifest.webmanifest') }}">
    <link rel="icon" href="{{ url_for('static', filename='icons/icon.svg') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.min.js"></script>
</head>
<body class="arena-body">
    <div id="network-status-banner" class="network-banner online">Online</div>

    <main id="arena" class="mobile-arena">
        <header class="arena-header mobile-arena-header">
            <div>
                <h1>Ambition Arena</h1>
                <p>Round <span id="round">1</span> — <span id="phase-label">Set Phase</span></p>
            </div>

            <a href="{{ url_for('index') }}" class="btn btn-secondary small-btn">Leave</a>
        </header>

        <section class="arena-tip-panel">
            <strong>Turn Guide</strong>
            <span id="arena-step-text">Choose an Intent, play your cards, optionally prepare Ambition Unleash, then press Ready.</span>
        </section>

        <details class="arena-rules-panel">
            <summary>Quick Rules</summary>
            <div class="quick-rules-grid">
                <div><strong>Strike</strong><span>+200 power if you win. If you lose, take +100 extra damage.</span></div>
                <div><strong>Guard</strong><span>Reduce incoming damage by 300 this round.</span></div>
                <div><strong>Focus</strong><span>If you survive this round, gain +2 Ambition.</span></div>
                <div><strong>Unleash</strong><span>Spend 5 Ambition to give your monster +300 power this battle.</span></div>
                <div><strong>Overreach</strong><span>If Ambition exceeds 10, take 300 damage and reset to 7.</span></div>
                <div><strong>Elements</strong><span>Fire &gt; Plant &gt; Earth &gt; Water &gt; Fire. Advantage gives +300 power.</span></div>
            </div>
        </details>

        <section class="mobile-hp-row">
            <div class="compact-player-card enemy-compact">
                <span id="enemy-name">Searching...</span>
                <strong id="enemy-hp">4000</strong>
                <small>Enemy HP</small>
            </div>

            <div class="round
cd /Users/lucassilverio/Desktop/Ambition
source .venv/bin/activate

cat > game/state.py <<'EOF'
AMBITION_MAX = 10
AMBITION_UNLEASH_COST = 5
AMBITION_UNLEASH_POWER_BONUS = 300
OVERREACH_PENALTY_DAMAGE = 300
OVERREACH_RESET_VALUE = 7

VALID_INTENTS = ["Strike", "Guard", "Focus"]

INTENT_RULES = {
    "Strike": {
        "label": "Strike",
        "description": "+200 power if you win the clash. If you lose, receive +100 extra damage.",
        "win_power_bonus": 200,
        "lose_extra_damage": 100,
        "damage_reduction": 0,
        "survive_ambition": 0,
    },
    "Guard": {
        "label": "Guard",
        "description": "Reduce received damage by 300 this round.",
        "win_power_bonus": 0,
        "lose_extra_damage": 0,
        "damage_reduction": 300,
        "survive_ambition": 0,
    },
    "Focus": {
        "label": "Focus",
        "description": "If you survive the round, gain +2 Ambition.",
        "win_power_bonus": 0,
        "lose_extra_damage": 0,
        "damage_reduction": 0,
        "survive_ambition": 2,
    },
}


def create_player_state(user, sid, deck, hand):
    return {
        "sid": sid,
        "user_id": user.id,
        "name": user.username,
        "hp": 4000,
        "deck": deck,
        "hand": hand,
        "graveyard": [],
        "field_m": None,
        "field_st": None,
        "ready": False,
        "shield": 0,
        "energy": 0,
        "max_energy": 0,
        "ambition": 0,
        "wants_unleash": False,
        "ambition_unleashed": False,
        "overreach_count": 0,
        "intent": "Strike",
    }


def create_match_state(player_one, player_two):
    return {
        "p1": player_one,
        "p2": player_two,
        "round": 1,
        "phase": "Set Phase",
        "resolving": False,
        "logs": [],
    }


def normalize_intent(intent):
    if intent not in VALID_INTENTS:
        return "Strike"

    return intent


def set_player_intent(player, intent):
    player["intent"] = normalize_intent(intent)


def reset_round_flags(player):
    player["ambition_unleashed"] = False
    player["wants_unleash"] = False
    player["intent"] = "Strike"


def get_intent_rule(player):
    intent = normalize_intent(player.get("intent", "Strike"))
    return INTENT_RULES[intent]
