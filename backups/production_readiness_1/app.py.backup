@app.route("/admin")
def admin_dashboard():
    admin_redirect = admin_required_redirect()

    if admin_redirect:
        return admin_redirect

    total_users = User.query.count()
    total_matches = MatchHistory.query.count()
    total_cards_tracked = CardStat.query.count()
    total_feedbacks = FeedbackReport.query.count()
    open_feedbacks = FeedbackReport.query.filter_by(status="open").count()
    total_boosters = BoosterHistory.query.count()

    all_matches = MatchHistory.query.all()
    average_rounds = 0

    if all_matches:
        average_rounds = round(sum(match.total_rounds for match in all_matches) / len(all_matches), 2)

    total_wins = sum(user.wins for user in User.query.all())
    total_losses = sum(user.losses for user in User.query.all())

    intent_metrics = {
        "Strike": 0,
        "Guard": 0,
        "Focus": 0,
        "Unleash": 0,
        "Overreach": 0,
    }

    for match in all_matches:
        logs = []

        try:
            logs = json.loads(match.battle_log_json or "[]")
        except Exception:
            logs = []

        for log_line in logs:
            line = str(log_line)

            if " chose Strike intent" in line or "selected Strike intent" in line:
                intent_metrics["Strike"] += 1

            if " chose Guard intent" in line or "selected Guard intent" in line:
                intent_metrics["Guard"] += 1

            if " chose Focus intent" in line or "selected Focus intent" in line:
                intent_metrics["Focus"] += 1

            if "unleashed Ambition" in line or "Ambition Unleash" in line:
                intent_metrics["Unleash"] += 1

            if "Overreach" in line:
                intent_metrics["Overreach"] += 1

    top_cards = (
        CardStat.query
        .order_by(CardStat.times_played.desc(), CardStat.wins_when_played.desc())
        .limit(10)
        .all()
    )

    best_cards = (
        CardStat.query
        .filter(CardStat.times_played >= 1)
        .order_by(CardStat.wins_when_played.desc(), CardStat.times_played.desc())
        .limit(10)
        .all()
    )

    recent_matches = (
        MatchHistory.query
        .order_by(MatchHistory.created_at.desc())
        .limit(10)
        .all()
    )

    return render_template(
        "admin.html",
        user=current_user(),
        total_users=total_users,
        total_matches=total_matches,
        total_cards_tracked=total_cards_tracked,
        total_feedbacks=total_feedbacks,
        open_feedbacks=open_feedbacks,
        total_boosters=total_boosters,
        intent_metrics=intent_metrics,
        average_rounds=average_rounds,
        total_wins=total_wins,
        total_losses=total_losses,
        top_cards=top_cards,
        best_cards=best_cards,
        recent_matches=recent_matches,
        recent_feedbacks=FeedbackReport.query.order_by(FeedbackReport.created_at.desc()).limit(10).all(),
    )


@app.route("/forgot-password", methods=["GET", "POST"])
def forgot_password():
    if request.method == "POST":
        email = request.form.get("email", "").strip().lower()
        user = User.query.filter_by(email=email).first()

        if user:
            token = secrets.token_urlsafe(48)
            user.reset_token = token
            user.reset_token_expires_at = datetime.now(timezone.utc) + timedelta(hours=2)
            db.session.commit()

            reset_url = url_for("reset_password", token=token, _external=True)
            send_password_reset_email(user.email, reset_url)

            print("\n--- AMBITION PASSWORD RESET LINK ---")
            print(reset_url)
            print("------------------------------------\n")

        flash("If this email exists, a reset link has been sent.")
        return redirect("/login")

    return render_template("forgot_password.html")


@app.route("/reset-password/<token>", methods=["GET", "POST"])
def reset_password(token):
    user = User.query.filter_by(reset_token=token).first()

    if not user:
        flash("Invalid reset link.")
        return redirect("/login")

    expires_at = user.reset_token_expires_at

    if expires_at and expires_at.tzinfo is None:
        expires_at = expires_at.replace(tzinfo=timezone.utc)

    if expires_at and expires_at < datetime.now(timezone.utc):
        flash("Reset link expired.")
        return redirect("/forgot-password")

    if request.method == "POST":
        password = request.form.get("password", "").strip()
        password_confirm = request.form.get("password_confirm", "").strip()

        if len(password) < 6:
            flash("Password must have at least 6 characters.")
            return redirect(request.path)

        if password != password_confirm:
            flash("Passwords do not match.")
            return redirect(request.path)

        user.set_password(password)
        user.reset_token = None
        user.reset_token_expires_at = None

        db.session.commit()

        flash("Password changed. You can login now.")
        return redirect("/login")

    return render_template("reset_password.html")




