def current_user():
    if "user_id" not in session:
        return None

    return db.session.get(User, session["user_id"])



def admin_required_redirect():
    auth_redirect = login_required_redirect()

    if auth_redirect:
        return auth_redirect

    user = current_user()

    if not user or not user.is_admin:
        flash("Admin access required.")
        return redirect("/")

    return None


def login_required_redirect():
    if "user_id" not in session:
        return redirect("/login")

    user = current_user()

    if not user:
        session.clear()
        return redirect("/login")

    return None


def booster_pull():
    roll = random.random()

    if roll < 0.78:
        rarity = "Common"
    else:
        rarity = "Uncommon"

    pool = [card for card in CARD_CATALOG if card["rarity"] == rarity]

    if not pool:
        pool = CARD_CATALOG

    return random.choice(pool).copy()


def parse_battle_logs(match):
    logs = match.get("logs", [])

    if not isinstance(logs, list):
        return []

    clean_logs = []

    for item in logs[-80:]:
        clean_logs.append(str(item)[:500])

    return clean_logs


def save_match_history(room_id, winner_key):
    match = active_matches.get(room_id)

    if not match:
        return

    p1 = match["p1"]
    p2 = match["p2"]

    winner_id = None
    winner_name = None
    result = "DRAW"

    if winner_key == "p1":
        winner_id = p1["user_id"]
        winner_name = p1["name"]
        result = "P1_WIN"

    elif winner_key == "p2":
        winner_id = p2["user_id"]
        winner_name = p2["name"]
        result = "P2_WIN"

    elif winner_key == "DRAW":
        result = "DRAW"

    history = MatchHistory(
        player1_id=p1["user_id"],
        player2_id=p2["user_id"],
        winner_id=winner_id,
        player1_name=p1["name"],
        player2_name=p2["name"],
        winner_name=winner_name,
        result=result,
        player1_final_hp=int(p1.get("hp", 0)),
        player2_final_hp=int(p2.get("hp", 0)),
        total_rounds=max(0, int(match.get("round", 1)) - 1),
        battle_log_json=json.dumps(parse_battle_logs(match)),
    )

    db.session.add(history)
    db.session.commit()



def get_or_create_card_stat(card):
    stat = CardStat.query.filter_by(card_id=card["id"]).first()

    if stat:
        return stat

    stat = CardStat(
        card_id=card["id"],
        card_name=card.get("name", card["id"]),
        card_type=card.get("type", "Unknown"),
        element=card.get("element", "Global"),
        rarity=card.get("rarity", "Common"),
    )

    db.session.add(stat)
    return stat


def collect_played_cards(player):
    played_cards = []

    for card in player.get("graveyard", []):
        if card:
            played_cards.append(card)

    for card in [player.get("field_m"), player.get("field_st")]:
        if card:
            played_cards.append(card)

    unique_cards = {}

    for card in played_cards:
        card_id = card.get("id")

        if card_id:
            unique_cards[card_id] = card

    return list(unique_cards.values())


def update_card_stats_after_match(match, winner_key):
    p1_cards = collect_played_cards(match["p1"])
    p2_cards = collect_played_cards(match["p2"])

    for card in p1_cards:
        stat = get_or_create_card_stat(card)
        stat.games_seen += 1
        stat.times_played += 1

        if winner_key == "p1":
            stat.wins_when_played += 1
        elif winner_key == "p2":
            stat.losses_when_played += 1
        else:
            stat.draws_when_played += 1

    for card in p2_cards:
        stat = get_or_create_card_stat(card)
        stat.games_seen += 1
        stat.times_played += 1

        if winner_key == "p2":
            stat.wins_when_played += 1
        elif winner_key == "p1":
            stat.losses_when_played += 1
        else:
            stat.draws_when_played += 1

