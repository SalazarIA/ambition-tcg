@app.route("/card-stats")
def card_stats():
    stats = (
        CardStat.query
        .order_by(
            CardStat.times_played.desc(),
            CardStat.wins_when_played.desc(),
            CardStat.card_name.asc(),
        )
        .limit(150)
        .all()
    )

    enriched_stats = []

    for stat in stats:
        card = get_card_by_id(stat.card_id)
        enriched_stats.append({
            "stat": stat,
            "card": card,
        })

    return render_template(
        "card_stats.html",
        user=current_user(),
        enriched_stats=enriched_stats,
    )


