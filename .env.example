ENVIRONMENT=development
DEBUG_MODE=true

SECRET_KEY=change_this_to_a_long_random_secret

DATABASE_URL=sqlite:///instance/database.db

PUBLIC_BASE_URL=http://127.0.0.1:8080
SOCKETIO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=true

LOGIN_ATTEMPT_LIMIT=8
LOGIN_ATTEMPT_WINDOW_MINUTES=15
PASSWORD_RESET_RATE_LIMIT=5
PASSWORD_RESET_RATE_WINDOW_MINUTES=60
BETA_EVENT_RATE_LIMIT=60
BETA_EVENT_RATE_WINDOW_SECONDS=60
RETENTION_EVENT_RATE_LIMIT=120
RETENTION_EVENT_RATE_WINDOW_SECONDS=60
FEEDBACK_DAILY_LIMIT=10
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_COMPLEXITY=true
MATCHMAKING_BOT_FALLBACK_SECONDS=10
BETA_AUTO_VERIFY=true

# Optional real email setup.
# Keep EMAIL_LOG_BODY_ENABLED=false outside local development to avoid leaking tokens.
EMAIL_LOG_BODY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=
