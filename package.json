{
  "name": "ambition-tcg",
  "version": "0.1.0",
  "description": "Ambitionz beta client wrappers for Android, iOS and Desktop.",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "author": "Lucas Silverio",
  "license": "UNLICENSED",
  "scripts": {
    "flask": "python app.py",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync:android": "npx cap sync android",
    "cap:sync:ios": "npx cap sync ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "android": "npx cap sync android && npx cap open android",
    "ios": "npx cap sync ios && npx cap open ios",
    "desktop": "electron .",
    "desktop:prod": "AMBITION_DESKTOP_URL=https://ambition-tcg.onrender.com electron .",
    "desktop:local": "AMBITION_DESKTOP_URL=http://127.0.0.1:8080 electron .",
    "arena3d:build": "vite build --config frontend/arena3d/vite.config.ts",
    "arena3d:assets:inspect": "gltf-transform inspect static/assets/arena3d/models/*.glb",
    "arena3d:assets:optimize": "gltf-transform optimize",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --mac --win --linux",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:copy": "npx cap copy android",
    "android:studio": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@gltf-transform/cli": "^4.3.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "build": {
    "appId": "com.elementra.ambitiontcg",
    "productName": "Ambitionz",
    "copyright": "Copyright © 2026 Lucas Silverio",
    "directories": {
      "output": "release",
      "buildResources": "desktop/assets"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
